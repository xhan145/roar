<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*" Name="ROAR" Language="1033" Version="$(var.AppVersion)"
           Manufacturer="xhan145"
           UpgradeCode="a7a83e4a-83a0-4834-8edc-8dc058eb254f">
    <Package InstallerVersion="500" Compressed="yes" InstallScope="perUser"
             Description="ROAR - local voice-to-text dictation" />
    <MajorUpgrade AllowSameVersionUpgrades="yes"
                  DowngradeErrorMessage="A newer version of ROAR is already installed." />
    <!-- External multi-CAB, mszip: an .msi FILE is hard-capped at 2 GB
         (structured storage), so the ~2.8 GB payload must live in roar*.cab
         files next to the .msi — msiexec finds them by name. mszip because
         the model weights are already-compressed tensors; 'high' would burn
         ~an hour for near-zero gain. -->
    <MediaTemplate EmbedCab="no" CompressionLevel="mszip"
                   MaximumUncompressedMediaSize="1024"
                   CabinetTemplate="roar{0}.cab" />
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="LocalAppDataFolder">
        <Directory Id="ProgramsFolder" Name="Programs">
          <Directory Id="INSTALLDIR" Name="ROAR" />
        </Directory>
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="AppMenuFolder" Name="ROAR" />
      </Directory>
    </Directory>
    <DirectoryRef Id="AppMenuFolder">
      <Component Id="StartMenuShortcut"
                 Guid="ba071046-31e9-4dde-95ba-54fdc712cd9e">
        <Shortcut Id="AppShortcut" Name="ROAR"
                  Target="[INSTALLDIR]ROAR.exe"
                  WorkingDirectory="INSTALLDIR" />
        <RemoveFolder Id="RemoveAppMenu" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\ROAR" Name="installed"
                       Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </DirectoryRef>
    <Feature Id="Main" Title="ROAR" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>
  </Product>
</Wix>
